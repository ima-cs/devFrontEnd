# Supabase — copie ce fichier en `.env.local` et remplis les valeurs.
# Tu trouves ces clés dans : Supabase > Project Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Email du compte administrateur (le signup avec cet email recevra automatiquement le rôle admin).
NEXT_PUBLIC_ADMIN_EMAIL=admin@servicepro.com
